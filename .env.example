# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api
API_VERSION=1
APP_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=openeos
DATABASE_PASSWORD=openeos_dev_password
DATABASE_NAME=openeos
DATABASE_SYNCHRONIZE=false
DATABASE_LOGGING=true
DATABASE_MIGRATIONS_RUN=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRATION=30m
JWT_REFRESH_TOKEN_EXPIRATION=7d

# CORS
# In production, must also include the marketing site domain(s) so
# /public/contact can be called from there, e.g.
# https://openeos.de,https://www.openeos.de
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=300

# SumUp (Mock for development)
SUMUP_API_KEY=
SUMUP_MERCHANT_CODE=
SUMUP_WEBHOOK_SECRET=

# File Storage (Mock for development)
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads

# Email (Mock for development)
EMAIL_ENABLED=false
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@openeos.de
# Recipient for "new registration" admin notifications. Falls back to
# ADMIN_EMAIL below if unset; leave both empty to disable the notification.
ADMIN_NOTIFY_EMAIL=

# Two-Factor Authentication (2FA)
# REQUIRED in production - encryption key for TOTP secrets (min 32 chars)
TWO_FACTOR_ENCRYPTION_KEY=
# Issuer name shown in authenticator apps
TWO_FACTOR_ISSUER=OpenEOS
# Email OTP expiry in minutes
EMAIL_OTP_EXPIRY_MINUTES=5
# Trusted device cookie expiry in days
TRUSTED_DEVICE_EXPIRY_DAYS=30

# Stripe (Payment Processing)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Sentry (Error Tracking & Performance Monitoring)
SENTRY_DSN=
# Optional: Override release version (defaults to package.json version)
# SENTRY_RELEASE=

# Initial Admin (for seeding)
# Also used as the fallback recipient for registration notifications
# if ADMIN_NOTIFY_EMAIL above isn't set.
ADMIN_EMAIL=admin@openeos.local
ADMIN_PASSWORD=Admin123!

# Event-Abrechnung (Pay-per-Event-Freischaltung)
# Preis pro Veranstaltung in Euro. Hinweis § 19 UStG: Kleinunternehmerregelung —
# der Preis ist ein Endpreis, es wird keine Umsatzsteuer ausgewiesen.
EVENT_PRICE_EUR=25
# Maximale Anzahl Bestellungen im Test-Modus, bevor die Veranstaltung
# freigeschaltet werden muss.
TEST_EVENT_MAX_ORDERS=25
# Optional: API-Key für die Firmensuche (openregister.de) im Kauf-auf-Rechnung-
# Formular. Leer lassen, um die Funktion zu deaktivieren.
OPENREGISTER_API_KEY=

# Support-Chat Telegram-Bridge (optional)
# Bot über @BotFather anlegen und den Token hier eintragen.
SUPPORT_TELEGRAM_BOT_TOKEN=
# ID der Telegram-Gruppe mit aktivierten Themen (Forum), meist negativ
# (z. B. -1001234567890). Der Bot muss als Admin mit dem Recht
# "Themen verwalten" (Manage Topics) in die Gruppe eingeladen werden.
# Leer lassen, um die Telegram-Anbindung zu deaktivieren.
SUPPORT_TELEGRAM_CHAT_ID=

# Zeitzone für stundenbasierte Auswertungen (Default: Europe/Berlin)
REPORT_TIMEZONE=Europe/Berlin
